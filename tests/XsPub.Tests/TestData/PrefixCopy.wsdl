<?xml version="1.0" encoding="utf-8"?>
<definitions xmlns="http://schemas.xmlsoap.org/wsdl/"
             xmlns:tns="http://example.com/tns"
             xmlns:tn="http://example.com/tn"
             xmlns:unused="http://example.com/unused"
             targetNamespace="http://example.com/tns">
  <types>
    <!-- Schema does not explicitly declare any of the three prefixes above; all are
         inherited from the definitions root.  copyPrefixes should:
           - propagate xmlns:tns  (used via type="tns:Foo")
           - not propagate xmlns:tn  ("tn:" does not appear in any QName attribute)
           - not propagate xmlns:unused  (never referenced at all) -->
    <xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" targetNamespace="http://example.com/tns">
      <xs:element name="Root" type="tns:Foo"/>
      <xs:complexType name="Foo"/>
    </xs:schema>
  </types>
</definitions>
